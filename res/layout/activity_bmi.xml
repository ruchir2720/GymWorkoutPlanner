<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#061225">

    <!-- MAIN CONTENT -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp">

        <!-- HERO SECTION -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BODY ANALYTICS"
                android:textColor="#C7D2FE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_small_chip"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI Calculator"
                android:textColor="#EAF0FF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calculate your Body Mass Index instantly."
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CONVERTER TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Height Converter"
            android:textColor="#7C89B6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <!-- FEET + INCHES -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <!-- FEET -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#111D34"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FEET"
                        android:textColor="#7C89B6"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etFeet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="5"
                        android:textColor="#EAF0FF"
                        android:textColorHint="#334155"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:inputType="number"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- INCHES -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="88dp"
                android:layout_weight="1"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#111D34"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INCHES"
                        android:textColor="#7C89B6"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etInches"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="10"
                        android:textColor="#EAF0FF"
                        android:textColorHint="#334155"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:inputType="number"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- CONVERT BUTTON -->

        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="Convert To CM"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_blue_button"/>

        <!-- HEIGHT CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="102dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="#111D34"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Height"
                    android:textColor="#7C89B6"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etHeight"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@android:color/transparent"
                    android:hint="180"
                    android:textColor="#EAF0FF"
                    android:textColorHint="#25324B"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:inputType="numberDecimal"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="cm"
                    android:textColor="#D7E3FF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <!-- WEIGHT CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="102dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="#111D34"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight"
                    android:textColor="#7C89B6"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etWeight"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@android:color/transparent"
                    android:hint="75"
                    android:textColor="#EAF0FF"
                    android:textColorHint="#25324B"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:inputType="numberDecimal"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="kg"
                    android:textColor="#D7E3FF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <!-- CALCULATE BUTTON -->

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Calculate BMI ⚡"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_blue_button"/>

        <!-- RESULT CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="#111D34"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imgBMIStatus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="#2563EB"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Awaiting Vitals"
                    android:textColor="#EAF0FF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your BMI result will appear here."
                    android:textColor="#7C89B6"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- BOTTOM NAV -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:background="#0B162B"
        app:itemIconTint="#A5B4FC"
        app:itemTextColor="#A5B4FC"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>