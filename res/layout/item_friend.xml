<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#111C34"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- TOP ROW -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- PROFILE IMAGE -->

            <ImageView
                android:id="@+id/imgFriend"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@drawable/bg_profile_circle"/>

            <!-- USER INFO -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvFriendName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friend"
                    android:textColor="#FFFFFF"
                    android:textSize="21sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvActivity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Road to 140kg bench"
                    android:textColor="#C7D2FE"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- RIGHT SIDE -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2m ago"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"/>

                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginTop="8dp"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="#94A3B8"/>
            </LinearLayout>

        </LinearLayout>

        <!-- DIVIDER -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E293B"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"/>

        <!-- BUTTONS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- CHEER -->

            <androidx.cardview.widget.CardView
                android:id="@+id/btnCheer"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#16213E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 CHEER"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- MESSAGE -->

            <androidx.cardview.widget.CardView
                android:id="@+id/btnMessage"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#16213E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="14sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>