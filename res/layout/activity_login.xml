<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".LoginActivity">

    <!-- TOP SECTION -->

    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Premium Pill -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_green"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="28dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_green"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREMIUM ACCESS"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>
        </LinearLayout>

        <!-- Logo -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R27FITCREW"
            android:textColor="@color/white"
            android:textSize="40sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"/>

        <!-- Subtitle -->

        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Professional grade performance tracking for the modern athlete."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

    <!-- CENTER HERO VISUAL -->

    <FrameLayout
        android:id="@+id/centerVisual"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtitle"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <!-- OUTER RING -->

        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_ring_outer"/>

        <!-- INNER RING -->

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_ring_inner"/>

        <!-- MAIN EMOJI -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🏋️"
            android:textSize="72sp"/>

        <!-- RANDOM FLOATING ICONS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💪"
            android:textSize="18sp"
            android:alpha="0.75"
            android:layout_marginStart="28dp"
            android:layout_marginTop="60dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="20sp"
            android:alpha="0.8"
            android:layout_gravity="end"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="85dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡"
            android:textSize="18sp"
            android:alpha="0.65"
            android:layout_marginStart="70dp"
            android:layout_marginTop="220dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏃"
            android:textSize="16sp"
            android:alpha="0.7"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="58dp"
            android:layout_marginBottom="70dp"/>

    </FrameLayout>

    <!-- BOTTOM SHEET -->

    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="12dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="18dp"
        android:paddingBottom="28dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Handle -->

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/sheet_handle"
            android:layout_marginBottom="28dp"/>

        <!-- Welcome -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome "
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <!-- Subtitle -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue your fitness journey"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"/>

        <!-- Google Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogleSignIn"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="SIGN IN WITH GOOGLE"
            android:textAllCaps="false"
            android:textColor="@color/bg_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/white"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="32dp"
            app:icon="@android:drawable/ic_dialog_email"
            app:iconGravity="textStart"
            app:iconTint="#202020"
            app:iconPadding="14dp"/>



        <!-- Terms -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By continuing, you agree to our Terms of Service and Privacy Policy"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="26dp"/>
    </LinearLayout>

    <!-- BOTTOM STATS -->

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LEFT -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="247+"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORKOUTS"
                android:textColor="@color/text_muted"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- RIGHT -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18.5K"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE USERS"
                android:textColor="@color/text_muted"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>