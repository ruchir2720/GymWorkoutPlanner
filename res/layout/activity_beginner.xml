<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#081120">

    <!-- HERO HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="34dp"
        android:paddingBottom="18dp">

        <!-- MINI TAG -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦ ELITE FOUNDATION"
            android:textColor="#C7D2FE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tag"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Beginner Guide"
            android:textColor="#FFFFFF"
            android:textSize="38sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>

        <!-- DESCRIPTION -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Unlock your peak potential with curated training fundamentals. Build strength, confidence, and perfect form from day one."
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <!-- TUTORIAL LIST -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTutorials"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp"
        android:clipToPadding="false"/>

    <!-- BOTTOM NAV -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="#A5B4FC"
        app:itemTextColor="#A5B4FC"
        app:itemIconSize="26dp"
        app:itemActiveIndicatorStyle="@null"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>