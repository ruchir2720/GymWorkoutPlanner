<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#070F1E">

    <!-- TOP BAR -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="24dp"
        android:background="#081120">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#DDE7FF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="R27FitCrew"
            android:textColor="#DDE7FF"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginStart="18dp"/>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_help"
            app:tint="#DDE7FF"/>
    </LinearLayout>

    <!-- MAIN CONTENT -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp">

        <!-- LABEL -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRAINING SESSION"
            android:textColor="#7F8BA8"
            android:textSize="14sp"
            android:letterSpacing="0.18"
            android:textStyle="bold"/>

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvWorkoutDay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chest"
                android:textColor="#EAF1FF"
                android:textSize="34sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:text="+ Add"
                android:textAllCaps="false"
                android:textColor="#DDE7FF"
                android:textSize="13sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:backgroundTint="#1A2740"
                app:cornerRadius="23dp"/>
        </LinearLayout>

        <!-- EMPTY -->

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No exercises added yet."
            android:textColor="#7F8BA8"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone"/>

        <!-- SCROLLABLE EXERCISES -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerExercises"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="10dp"
            android:overScrollMode="never"/>

        <!-- FIXED FINISH BUTTON -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinishWorkout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="14dp"
            android:text="Finish Workout"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1D5CF2"
            app:cornerRadius="28dp"/>

        <!-- RECENT SESSIONS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Sessions"
            android:textColor="#DDE7FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvEmptyHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No workout sessions saved yet.\nFinish a workout to see your history here."
            android:textColor="#7182A7"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="18dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerWorkoutHistory"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:overScrollMode="never"/>

    </LinearLayout>

</LinearLayout>